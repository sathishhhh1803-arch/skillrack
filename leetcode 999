#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int numRookCaptures(vector<vector<char>>& board) {
        int ans = 0;
        int i0 = 0, j0 = 0;

        for (int i = 0; i < 8; ++i) {
            for (int j = 0; j < 8; ++j) {
                if (board[i][j] == 'R') {
                    i0 = i;
                    j0 = j;
                }
            }
        }

        vector<vector<int>> dirs = {{1, 0}, {0, 1}, {-1, 0}, {0, -1}};

        for (const vector<int>& d : dirs) {
            int i = i0 + d[0];
            int j = j0 + d[1];

            while (0 <= i && i < 8 && 0 <= j && j < 8) {
                if (board[i][j] == 'p') {
                    ++ans;
                    break;
                }
                if (board[i][j] != '.') {
                    break;
                }
                i += d[0];
                j += d[1];
            }
        }

        return ans;
    }
};

